# YouTube upload — copy to scripts/.env or scripts/youtube/.env (never commit .env)
# See docs/youtube/HANDOFF.md for full setup.

# Inbox folder (MP4 + manifest.csv + batch.yaml). Default: %USERPROFILE%\YOUTUBE\inbox
# YOUTUBE_INBOX=C:\Users\carlo\YOUTUBE\inbox

# After successful upload (default: {YOUTUBE_INBOX}/uploaded)
# YOUTUBE_UPLOADED_DIR=C:\Users\carlo\YOUTUBE\inbox\uploaded

# Fallback OAuth Desktop JSON (prefer ~/.secrets/api-keys.json -> google_oauth_youtube)
# YOUTUBE_CLIENT_SECRETS=C:\Users\carlo\.secrets\scripts\youtube_client_secret.json

# Fallback token file (also merged into api-keys after --auth-only)
# YOUTUBE_TOKEN_PATH=C:\Users\carlo\.secrets\scripts\youtube_token.json

# First-time OAuth / refresh YouTube scopes:
#   python scripts/youtube-upload.py --auth-only
